---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { apps } from '../data/apps';
const aSecuriser = apps.filter(a => a.status === 'a-securiser');
const nbSafe = apps.filter(a => a.status === 'actif').length;
const nbArchive = apps.filter(a => a.status === 'archive').length;
---
<BaseLayout title="Sécurité">
  <Fragment slot="header"><Header /></Fragment>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-24 text-center">
    <span class="text-7xl sm:text-8xl block mb-6">🔒</span>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Sécurité</h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto">Protection du portail et état des projets.</p>
  </section>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16">
    <SectionTitle title="Protection" subtitle="Comment home.sagetech.vip est protégé" />
    <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 mt-8 space-y-4">
      <div class="flex items-start gap-3"><span class="text-lg">1️⃣</span><div><h3 class="text-white font-semibold">Coolify HTTP Basic Auth</h3><p class="text-gray-400 text-sm">Identifiant + mot de passe configurés dans Coolify. Aucun secret dans le code.</p></div></div>
      <div class="flex items-start gap-3"><span class="text-lg">2️⃣</span><div><h3 class="text-white font-semibold">Cloudflare Tunnel</h3><p class="text-gray-400 text-sm">Trafic via Cloudflare. Aucune IP serveur exposée.</p></div></div>
      <div class="flex items-start gap-3"><span class="text-lg">3️⃣</span><div><h3 class="text-white font-semibold">Aucun secret dans le code</h3><p class="text-gray-400 text-sm">Clés dans .env ou variables Coolify. Jamais commitées.</p></div></div>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-16">
    <SectionTitle title="Projets à sécuriser" />
    {aSecuriser.length > 0 ? (
      <div class="space-y-3 mt-8">{aSecuriser.map(app => (
        <div class="bg-rose-500/5 border border-rose-500/20 rounded-xl p-4">
          <div class="flex items-center justify-between">
            <div><h3 class="text-white font-semibold">🔴 {app.name}</h3><p class="text-gray-400 text-sm mt-1">{app.nextAction}</p></div>
            <a href={`/apps/${app.slug}`} class="text-rose-400 text-sm hover:text-rose-300 shrink-0">Détails →</a>
          </div>
        </div>
      ))}</div>
    ) : <p class="text-green-400 mt-8">✅ Aucun projet à sécuriser.</p>}
    <p class="text-sm text-gray-500 mt-4">✅ {nbSafe} sûr(s) · ⚪ {nbArchive} archivé(s)</p>
  </section>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-24">
    <SectionTitle title="Recommandations" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5"><h3 class="text-white font-semibold mb-2">🔑 Jamais de secrets dans le code</h3><p class="text-gray-400 text-sm">Clés API et tokens dans .env uniquement.</p></div>
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5"><h3 class="text-white font-semibold mb-2">🛡️ Clés Supabase anon uniquement</h3><p class="text-gray-400 text-sm">La clé service_role jamais dans le frontend.</p></div>
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5"><h3 class="text-white font-semibold mb-2">📋 RLS activé</h3><p class="text-gray-400 text-sm">Row Level Security même en lecture publique.</p></div>
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5"><h3 class="text-white font-semibold mb-2">🔍 Audit régulier</h3><p class="text-gray-400 text-sm">Détecter les secrets exposés dans les dépôts.</p></div>
    </div>
  </section>
  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>