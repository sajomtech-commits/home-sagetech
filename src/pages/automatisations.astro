---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { automatons } from '../data/index';

// Filtrer les automatons par plateforme
const n8nAutomatons = automatons.filter((a) => a.platform === 'n8n');
const hermesAutomatons = automatons.filter((a) => a.platform.includes('Hermes'));
const ideeAutomatons = automatons.filter((a) => a.status === 'idee');

// Carte d'automation (composant inline)
interface AutomationCardProps {
  icon: string;
  title: string;
  description: string;
  status: string;
}
---

<BaseLayout
  title="Automatisations"
  description="Workflows d'automatisation connectant Gmail, Dropbox, NAS et services cloud — propulsés par n8n, Hermes et Telegram."
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-24 text-center">
    <span class="text-7xl sm:text-8xl block mb-6">⚡</span>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Automatisations</h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto">
      Workflows et processus automatisés qui font tourner SageTech en coulisses.
    </p>
  </section>

  <!-- Scénarios n8n -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle
      title="⚙️ Scénarios n8n"
      subtitle="Automatisations en production avec n8n"
    />
    {n8nAutomatons.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {n8nAutomatons.map((a) => (
          <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 hover:border-gray-700 transition-colors">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl">{a.icon}</span>
              <div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                  actif
                </span>
              </div>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">{a.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{a.description}</p>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-center py-8">Aucune automatisation n8n actuellement.</p>
    )}
  </section>

  <!-- Automatisations Hermes & Telegram -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle
      title="🤖 Automatisations Hermes & Telegram"
      subtitle="Agents et crons gérés par Hermes Agent"
    />
    {hermesAutomatons.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {hermesAutomatons.map((a) => (
          <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 hover:border-gray-700 transition-colors">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl">{a.icon}</span>
              <div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                  actif
                </span>
              </div>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">{a.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{a.description}</p>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-center py-8">Aucune automatisation Hermes actuellement.</p>
    )}
  </section>

  <!-- Idées futures -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle
      title="💡 Idées futures"
      subtitle="Automatisations en attente de concrétisation"
    />
    {ideeAutomatons.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {ideeAutomatons.map((a) => (
          <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 hover:border-gray-700 transition-colors">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-3xl">{a.icon}</span>
              <div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20">
                  idée
                </span>
              </div>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">{a.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{a.description}</p>
            <div class="mt-3 pt-3 border-t border-gray-800">
              <span class="text-xs text-gray-500">Plateforme : {a.platform}</span>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-center py-8">Aucune idée d'automatisation pour le moment.</p>
    )}
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
