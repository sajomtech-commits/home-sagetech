---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { docSections } from '../data/index';

function renderInline(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong class="text-white">$1</strong>')
    .replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 rounded bg-gray-800 text-indigo-300 text-xs font-mono">$1</code>');
}

interface Block { type: 'h3' | 'h4' | 'p' | 'li' | 'code' | 'pre'; content: string; }

function parseMarkdown(md: string): Block[] {
  const lines = md.split('\n');
  const blocks: Block[] = [];
  let inCode = false;
  let codeAcc: string[] = [];
  for (const raw of lines) {
    if (raw.startsWith('```')) {
      if (inCode) {
        blocks.push({ type: 'pre', content: codeAcc.join('\n') });
        codeAcc = [];
        inCode = false;
      } else {
        inCode = true;
      }
      continue;
    }
    if (inCode) { codeAcc.push(raw); continue; }
    const s = raw.trim();
    if (!s) continue;
    if (s.startsWith('### ')) blocks.push({ type: 'h3', content: renderInline(s.replace('### ', '')) });
    else if (s.startsWith('## ')) blocks.push({ type: 'h3', content: renderInline(s.replace('## ', '')) });
    else if (s.startsWith('- ')) blocks.push({ type: 'li', content: renderInline(s.replace('- ', '')) });
    else blocks.push({ type: 'p', content: renderInline(s) });
  }
  if (inCode && codeAcc.length) blocks.push({ type: 'pre', content: codeAcc.join('\n') });
  return blocks;
}
---
<BaseLayout
  title="Documentation"
  description="Notes techniques, guides et documentation des projets SageTech."
>
  <Fragment slot="header"><Header /></Fragment>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-24 text-center">
    <span class="text-7xl sm:text-8xl block mb-6">📚</span>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Documentation</h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto">
      Notes techniques et guides de configuration des services et outils SageTech.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-24">
    <SectionTitle title="Notes techniques" subtitle="Références et bonnes pratiques" />
    <div class="flex flex-col gap-8 mt-8">
      {docSections.map((doc) => {
        const blocks = parseMarkdown(doc.content);
        return (
          <div id={doc.id} class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 sm:p-8 hover:border-gray-700 transition-colors">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{doc.icon}</span>
              <h2 class="text-xl font-bold text-white">{doc.title}</h2>
            </div>
            <p class="text-gray-400 mb-6">{doc.description}</p>
            <div class="max-w-3xl text-gray-300 leading-relaxed space-y-2">
              {blocks.map((b) => {
                if (b.type === 'h3') return <h3 class="text-white font-semibold text-lg mt-6 mb-2" set:html={b.content}></h3>;
                if (b.type === 'li') return <li class="text-gray-400 ml-4 mb-1.5 list-disc" set:html={b.content}></li>;
                if (b.type === 'pre') return <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 my-3 overflow-x-auto"><code class="text-sm font-mono text-gray-300" set:html={b.content}></code></pre>;
                return <p class="mb-1.5" set:html={b.content}></p>;
              })}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
