---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/index';

const actifs = projects.filter((p) => p.status === 'actif');
const enCours = projects.filter((p) => p.status === 'en-cours');
const idees = projects.filter((p) => p.status === 'idee');
---

<BaseLayout title="Accueil" description="Mon portail personnel pour centraliser projets, outils et automatisations.">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-24 sm:py-32">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight">
          SageTech Home
        </h1>
        <p class="mt-4 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto">
          Mon portail personnel pour centraliser projets, outils et automatisations.
        </p>
      </div>
    </div>
    <!-- Subtle gradient glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-indigo-500/10 blur-[120px] rounded-full"></div>
    </div>
  </section>

  <!-- Projets en vedette -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle title="Projets en vedette" subtitle="Les projets actuellement actifs et opérationnels." />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {actifs.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- En cours de développement -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle title="En cours de développement" subtitle="Projets en phase de conception ou de développement." />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {enCours.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- Idées -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <SectionTitle title="Idées" subtitle="Des concepts en attente de réalisation." />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {idees.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
