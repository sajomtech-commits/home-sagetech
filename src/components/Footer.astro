---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-800/60 mt-auto">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-sm">
      <div>
        <h3 class="font-semibold text-white mb-2">🏠 SageTech Home</h3>
        <p class="text-gray-500">Portail personnel centralisant projets, outils et automatisations.</p>
      </div>
      <div>
        <h3 class="font-semibold text-white mb-2">Navigation</h3>
        <ul class="space-y-1 text-gray-500">
          <li><a href="/projets" class="hover:text-gray-300 transition-colors">Projets</a></li>
          <li><a href="/veille-techno" class="hover:text-gray-300 transition-colors">Veille techno</a></li>
          <li><a href="/automatisations" class="hover:text-gray-300 transition-colors">Automatisations</a></li>
          <li><a href="/documentation" class="hover:text-gray-300 transition-colors">Documentation</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-white mb-2">Liens</h3>
        <ul class="space-y-1 text-gray-500">
          <li><a href="https://github.com/sajomtech-commits" target="_blank" class="hover:text-gray-300 transition-colors">GitHub</a></li>
          <li><a href="https://sajomtech-commits.github.io/YoFournisseur/" target="_blank" class="hover:text-gray-300 transition-colors">YoFournisseur</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-gray-800 text-center text-xs text-gray-600">
      &copy; {year} SageTech. Propulsé par ☕ et Astro.
    </div>
  </div>
</footer>
