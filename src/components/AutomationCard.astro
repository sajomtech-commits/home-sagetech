---
import type { Automation } from '../data/index';

export interface Props {
  automation: Automation;
}

const { automation } = Astro.props;

const statusColors: Record<string, string> = {
  actif: 'bg-emerald-500/15 text-emerald-400',
  'en-cours': 'bg-amber-500/15 text-amber-400',
  idee: 'bg-gray-500/15 text-gray-400',
};
---

<div class="rounded-xl border border-gray-800 bg-[#111118] p-5 transition-all duration-200 hover:border-indigo-500/30">
  <div class="flex items-center gap-3 mb-3">
    <span class="text-2xl">{automation.icon}</span>
    <div class="flex-1">
      <h3 class="font-semibold text-white">{automation.title}</h3>
      <span class="text-xs text-gray-500">{automation.platform}</span>
    </div>
    <span class="text-xs font-medium px-2.5 py-0.5 rounded-full {statusColors[automation.status]}">
      {automation.status}
    </span>
  </div>
  <p class="text-sm text-gray-400 leading-relaxed">{automation.description}</p>
</div>
