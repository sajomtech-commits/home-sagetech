---
import type { Project } from '../data/index';

export interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusColors: Record<string, string> = {
  actif: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  'en-cours': 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  'a-ameliorer': 'bg-rose-500/15 text-rose-400 border-rose-500/30',
  idee: 'bg-gray-500/15 text-gray-400 border-gray-500/30',
};

const statusLabels: Record<string, string> = {
  actif: 'Actif',
  'en-cours': 'En cours',
  'a-ameliorer': 'À améliorer',
  idee: 'Idée',
};
---

<a
  href={project.url}
  class="group block rounded-xl border border-gray-800 bg-[#111118] p-5 transition-all duration-200 hover:border-indigo-500/50 hover:bg-[#16161f] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-indigo-500/5"
>
  <div class="flex items-start justify-between mb-3">
    <span class="text-2xl">{project.icon}</span>
    <span class="text-xs font-medium px-2.5 py-0.5 rounded-full border {statusColors[project.status]}">
      {statusLabels[project.status]}
    </span>
  </div>
  <h3 class="font-semibold text-white mb-1.5 group-hover:text-indigo-300 transition-colors">
    {project.title}
  </h3>
  <p class="text-sm text-gray-400 leading-relaxed">{project.description}</p>
  <div class="flex flex-wrap gap-1.5 mt-3">
    {project.tags.slice(0, 3).map((tag) => (
      <span class="text-xs px-2 py-0.5 rounded-md bg-gray-800/60 text-gray-500">{tag}</span>
    ))}
  </div>
</a>
