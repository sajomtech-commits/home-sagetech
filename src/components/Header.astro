---
import { navigation } from '../data/navigation';
const p = Astro.url.pathname;
---
<header class="sticky top-0 z-50 border-b border-gray-800/60 bg-[#0a0a0f]/90 backdrop-blur-md">
  <nav class="mx-auto max-w-6xl flex items-center justify-between px-4 sm:px-6 h-14 gap-2">
    <a href="/" class="flex items-center gap-2 text-white font-bold text-lg hover:text-indigo-400 transition-colors shrink-0">
      <span>🏠</span>
      <span class="hidden sm:inline">SageTech</span>
    </a>
    <div class="flex items-center gap-0.5 overflow-x-auto no-scrollbar">
      {navigation.map((l) => (
        <a href={l.href}
          class:list={[
            'whitespace-nowrap px-2.5 py-1.5 rounded-lg text-sm font-medium transition-all duration-200',
            p === l.href ? 'bg-indigo-500/15 text-indigo-300' : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800/50',
          ]}>
          {l.icon}<span class="hidden sm:inline ml-1">{l.label}</span>
        </a>
      ))}
    </div>
  </nav>
</header>
<style is:global>.no-scrollbar::-webkit-scrollbar{display:none}.no-scrollbar{-ms-overflow-style:none;scrollbar-width:none}</style>