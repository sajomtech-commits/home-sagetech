---
export interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8">
  <h2 class="text-2xl sm:text-3xl font-bold text-white">{title}</h2>
  {subtitle && <p class="mt-2 text-gray-400">{subtitle}</p>}
  <div class="mt-3 h-0.5 w-16 rounded-full bg-gradient-to-r from-indigo-500 to-cyan-500"></div>
</div>
